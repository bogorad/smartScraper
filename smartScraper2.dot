digraph execution_logic {
    node[shape=box, style=filled, fillcolor=lightblue];
    edge[color=gray];

    node0[label="getContent(url)", fillcolor=lightgreen];
    node1[label="Error: No URL provided", shape=octagon, fillcolor=salmon];
    node2[label="Get Domain from URL"];
    node3[label="Load site_storage.json"];
    node4[label="Check for stored XPath/Cookie"];

    // Stage 1: Attempt with Stored Data
    subgraph cluster_stage1 {
        label = "Stage 1: Attempt Stored Data";
        style=dashed;
        color=blue;

        node5[label="fetchWithStoredData(url, storedXPath, storedCookie)", fillcolor=yellow];
        node6[label="fetchWithStoredData(url, storedXPath, null, null)", fillcolor=yellow];

        node7[label="navigateAndPreparePage (no explicit DD check)"];
        node8[label="Set Stored Cookie"];
        node9[label="Get HTML Content"];
        node10[label="Save HTML (Pre-Extract)"];
        node11[label="Extract HTML with Stored XPath"];
        node12[label="Extraction Successful", fillcolor=lightgreen];
        node13[label="Extraction Failed", fillcolor=salmon];
        node14[label="Save HTML (On Failure)"];
    }

    // Stage 2: Fallback to Discovery
    subgraph cluster_stage2 {
        label = "Stage 2: Discovery";
        style=dashed;
        color=red;

        node15[label="findArticleXPathAndExtract(url)", fillcolor=yellow];
        node16[label="navigateAndPreparePage (with explicit DD check)"];
        node17[label="Handle DataDome (if needed/configured)"];
        node18[label="Solve CAPTCHA (2Captcha)"];
        node19[label="Update Stored Cookie"];
        node20[label="Get HTML Content"];
        node21[label="Extract Snippets"];
        node22[label="Get LLM Candidate XPaths"];
        node23[label="Validate & Score XPaths"];
        node24[label="Select Best XPath"];
        node25[label="Update Stored XPath"];
        node26[label="Save HTML (Pre-Extract)"];
        node27[label="Extract HTML with Discovered XPath"];
        node28[label="Extraction Successful", fillcolor=lightgreen];
        node29[label="Discovery/Extraction Failed", fillcolor=salmon];
        node30[label="Save HTML (On Failure)"];
    }

    node31[label="Return Success (Content)", shape=doubleoctagon, fillcolor=lightgreen];
    node32[label="Return Error", shape=doubleoctagon, fillcolor=salmon];

    node33[label="End", shape=circle, fillcolor=lightgreen];
    node34[label="End", shape=circle, fillcolor=salmon];


    // Connections
    node0 -> node2;
    node2 -> node1[label="Invalid URL"];
    node2 -> node3[label="Valid URL"];
    node3 -> node4;

    // Logic based on stored data
    node4 -> node5[label="Stored Cookie & XPath"];
    node4 -> node6[label="Stored XPath Only"];
    node4 -> node15[label="No Stored Data"]; // Direct to discovery if nothing stored

    // Stage 1 Flow (Attempt with Cookie & XPath)
    node5 -> node7;
    node7 -> node8[label="Success"];
    node7 -> node13[label="Nav Failed"];
    node8 -> node9;
    node9 -> node10[label="HTML OK"];
    node9 -> node13[label="No HTML"];
    node10 -> node11;
    node11 -> node12[label="Extraction OK"];
    node11 -> node13[label="Extraction Failed"];

    // Stage 1 Flow (Attempt with XPath Only)
    node6 -> node7; // Reuses same nav_prep logic
    // node7 -> node13[label="Nav Failed"]; // Already linked above
    // node9 -> node10[label="HTML OK"]; // Already linked above
    // node9 -> node13[label="No HTML"]; // Already linked above
    // node10 -> node11; // Already linked above
    // node11 -> node12[label="Extraction OK"]; // Already linked above
    // node11 -> node13[label="Extraction Failed"]; // Already linked above

    node12 -> node31;
    node13 -> node14;
    node14 -> node15[label="Fallback to Discovery"]; // If Stage 1 fails, try Stage 2

    // Stage 2 Flow (Discovery)
    node15 -> node16;
    node16 -> node17[label="Success"];
    node16 -> node29[label="Nav Failed"];

    node17 -> node18[label="CAPTCHA Detected"];
    node17 -> node20[label="No CAPTCHA / Handled"];
    node17 -> node29[label="CAPTCHA Handling Failed"];

    node18 -> node19[label="Solved"];
    node18 -> node29[label="Solve Failed"];
    node19 -> node20;

    node20 -> node21[label="HTML OK"];
    node20 -> node29[label="No HTML"];

    node21 -> node22;
    node22 -> node23[label="Candidates"];
    node22 -> node29[label="No Candidates"];

    node23 -> node24[label="Valid Candidates"];
    node23 -> node29[label="No Valid Candidates"];

    node24 -> node25;
    node25 -> node26;
    node26 -> node27;
    node27 -> node28[label="Extraction OK"];
    node27 -> node29[label="Extraction Failed"];

    node28 -> node31;
    node29 -> node30;
    node30 -> node32; // If Stage 2 fails, return error

    // Final returns
    node31 -> node33;
    node32 -> node34;

}
