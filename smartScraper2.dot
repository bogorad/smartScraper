digraph execution_logic {
    node[shape=box, style=filled];

    start[label="getContent(url)"];
    error_no_url[label="Error: No URL provided"];
    config_check[label="Check if normalized URL in config"];
    fetch_with_stored_data[label="Fetch with stored data (XPath and cookie)"];
    use_cookie[label="Use stored cookie"];
    fetch_failed[label="Fetch failed"];
    captcha_detected[label="CAPTCHA detected"];
    solve_captcha[label="Solve CAPTCHA with 2Captcha"];
    update_cookie[label="Update cookie with new CAPTCHA solution"];
    extract_xpath[label="Extract XPath"];
    xpath_failed[label="XPath extraction failed"];
    find_better_xpath[label="Find better XPath"];
    update_config_xpath[label="Update config with new XPath"];
    return_error[label="Return error"];

    start -> config_check;
    config_check -> fetch_with_stored_data[label="yes"];
    config_check -> error_no_url[label="no"];

    fetch_with_stored_data -> use_cookie;
    use_cookie -> extract_xpath[label="success"];
    use_cookie -> fetch_failed[label="failure"];

    fetch_failed -> captcha_detected[label="CAPTCHA"];
    captcha_detected -> solve_captcha;
    solve_captcha -> update_cookie;
    update_cookie -> extract_xpath;

    extract_xpath -> return_error[label="failure"];
    extract_xpath -> find_better_xpath[label="failure"];

    find_better_xpath -> update_config_xpath[label="success"];
    find_better_xpath -> return_error[label="failure"];

    update_config_xpath -> return_error;
}
